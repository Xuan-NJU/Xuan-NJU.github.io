{% assign is_zh = false %}
{% if page.lang contains 'zh' %}{% assign is_zh = true %}{% endif %}
<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div class="table-responsive" {% if include.limit and page.announcements.scrollable and news_size > 3 %}style="max-height: 60vw"{% endif %}>
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 20%">
              <time datetime="{{ item.date | date: '%Y-%m' }}">
                {% if is_zh %}{{ item.date | date: '%Y 年 %m 月' }}{% else %}{{ item.date | date: '%b %Y' }}{% endif %}
              </time>
            </th>
            <td>
              {% if item.inline %}
                {% if is_zh and item.content_zh %}
                  {{ item.content_zh | markdownify | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% endif %}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>{% if is_zh %}暂无动态。{% else %}No news so far...{% endif %}</p>
  {% endif %}
</div>
