---
---
{% assign zh_entry = site.data.publications_zh[entry.key] %}
<div class="row">
  <div class="col col-sm-2 abbr">
    {% if entry.abbr %}
      <abbr
        class="badge rounded w-100"
        {% if site.data.venues[entry.abbr].color %}
          style="background-color: {{ site.data.venues[entry.abbr].color }}"
        {% endif %}
      >
        {% if site.data.venues[entry.abbr].url %}
          <a href="{{ site.data.venues[entry.abbr].url }}">{{ entry.abbr }}</a>
        {% else %}
          {{ entry.abbr }}
        {% endif %}
      </abbr>
    {% endif %}
  </div>

  <div id="{{ entry.key }}" class="col-sm-10">
    <div class="title">
      {% if zh_entry and zh_entry.title %}{{ zh_entry.title }}{% else %}{{ entry.title }}{% endif %}
      {% if zh_entry and zh_entry.title %}
        <span class="publication-original-title" lang="en">{{ entry.title }}</span>
      {% endif %}
    </div>

    <div class="author">
      {% for author in entry.author_array %}
        {% assign author_last_name = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' %}
        {% assign author_last_html = author.last | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' %}
        {% assign author_is_self = false %}
        {% if site.scholar.last_name contains author_last_name and site.scholar.first_name contains author.first %}
          {% assign author_is_self = true %}
        {% endif %}
        {% if author_is_self %}<em>{{ author.first }} {{ author_last_html }}</em>{% else %}{{ author.first }} {{ author_last_html }}{% endif %}{% unless forloop.last %}, {% endunless %}
      {% endfor %}
    </div>

    <div class="periodical">
      {% if entry.type == 'article' %}
        发表于 <em>{{ entry.journal }}</em>
      {% elsif entry.type == 'inproceedings' or entry.type == 'incollection' %}
        发表于 <em>{{ entry.booktitle }}</em>
      {% endif %}
      {% if zh_entry and zh_entry.date %}，{{ zh_entry.date }}{% elsif entry.year %}，{{ entry.year }} 年{% endif %}
    </div>
    {% if zh_entry and zh_entry.note %}<div class="periodical publication-note">{{ zh_entry.note }}</div>{% endif %}

    <div class="links">
      {% if entry.doi %}<a href="https://doi.org/{{ entry.doi }}" class="btn btn-sm z-depth-0" role="button">DOI</a>{% endif %}
      {% if entry.arxiv %}<a href="https://arxiv.org/abs/{{ entry.arxiv }}" class="btn btn-sm z-depth-0" role="button">arXiv</a>{% endif %}
      {% if entry.pdf %}
        <a href="{% if entry.pdf contains '://' %}{{ entry.pdf }}{% else %}{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}{% endif %}" class="btn btn-sm z-depth-0" role="button">PDF</a>
      {% endif %}
      {% if entry.bibtex_show %}<a class="bibtex btn btn-sm z-depth-0" role="button">BibTeX</a>{% endif %}
    </div>

    {% if entry.bibtex_show %}
      <div class="bibtex hidden">
        {% highlight bibtex %}
        {{- entry.bibtex | hideCustomBibtex -}}
        {% endhighlight %}
      </div>
    {% endif %}
  </div>
</div>
